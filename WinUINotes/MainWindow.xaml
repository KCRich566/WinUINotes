<?xml version="1.0" encoding="utf-8"?>
<!--xmlns 是用來「定義命名空間（namespace）」的-->
<!--x:Class="WinUINotes.MainWindow" 這裡的x:Class要與CS檔案的Namespace與Class名稱一致
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation": 預設的命名空間
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class, x:Name, x:Key, x:Bind
    xmlns:local="using:WinUINotes"
    計畫面（Designer）」生效
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc 是用來確保這些設計語法在執行時可以被忽略
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    
    使用using告知xaml是使用CLR的命名空間, 而不是XML
    xmlns:views="using:WinUINotes.Views"
    mc 告訴系統「忽略它沒關係」
    mc:Ignorable="d"
    -->
<Window
    x:Class="WinUINotes.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WinUINotes"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="using:WinUINotes.Views"
    mc:Ignorable="d"
    Title="WinUINotes">

    <!--設定屬性的方式: value是簡單型別可從字串轉換的如string, int bool, enum-->
    <!--<object attribute="value">只適用於 XAML 剖析器知道如何將字串轉換成預期的實值型別的值-->
    <!--或使用 屬性元素語法 來建立物件: value是UI元素, Brush, Style, Binding, Collection-->
    <!--<object ...>
        <object.property>
            value
        </object.property>
    </object>-->
    
    <!--設定整個視窗的系統背景效果-->
    <!--建立Mica(Windows11的材質)背景效果物件-->
    <Window.SystemBackdrop> 
        <MicaBackdrop Kind="Base"/>  
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <!--以下元素要定義Grid.Row=n才會放到對應的行-->
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <TitleBar x:Name="AppTitleBar" Title="WinUI Notes"
                  IsBackButtonVisible="True"
                  IsBackButtonEnabled="{x:Bind rootFrame.CanGoBack, Mode=OneWay}"
                  BackRequested="AppTitleBar_BackRequested">
            <TitleBar.IconSource>
                <FontIconSource Glyph="&#xF4AA;"/>
            </TitleBar.IconSource>
        </TitleBar>
        
        <!--Frame主要用來顯示不同的Page,並負責頁面切換(Navigation)-->
        <!--SourcePageType="views:AllNotesPage" 的views被xmlns(XML prefix別名)定義, 所以可以是自定義名稱-->
        <Frame x:Name="rootFrame" Grid.Row="1" SourcePageType="views:AllNotesPage"/>

    </Grid>
</Window>
