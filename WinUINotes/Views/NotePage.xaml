<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WinUINotes.Views.NotePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WinUINotes"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="16" RowSpacing="8">
        <Grid.RowDefinitions>
            <!--*: 佔滿剩餘空間-->
            <RowDefinition Height="*"/>
            <!--Auto: 高度隨內容變化自動調整-->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!--AcceptsReturn: 多行文字輸入的控制-->
        <!--Text="{x:Bind noteModel.Text, Mode=TwoWay}": 將Text與noteModel.Text繫結-->
        <!--Header="{x:Bind noteModel.Date.ToString()}": 將Header與noteModel.Date.ToString() 預設是One Time-->
        <!--這裡你沒有寫 Mode，那 預設就是單向 (OneTime) 或 OneWay)，在 x:Bind 裡：
        如果綁定的是 方法或表達式（像 ToString()），預設是 OneTime
        如果綁定的是 屬性，預設是 OneWay(Model 到Viewbox) -->
        <TextBox x:Name="NoteEditor"
                 Text="{x:Bind noteModel.Text, Mode=TwoWay}"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 PlaceholderText="Enter your note"
                 
                 Header="{x:Bind noteModel.Date.ToString()}"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 Width="400"
                 Grid.Column="1"/>
        <!--Spacing: 控制子元素之間的間距-->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="4"
                    Grid.Row="1"
                    Grid.Column="1">
            <!--StaticResource: 載入時就定義的資源-->
            <Button Content="Save" Style="{StaticResource AccentButtonStyle}" Click="SaveButton_Click"/>
            <Button Content="Delete" Click="DeleteButton_Click" />
        </StackPanel>

    </Grid>
</Page>
